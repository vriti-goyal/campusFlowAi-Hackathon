# ── MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/campusflow

# ── AWS ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
AWS_REGION=us-east-1
S3_BUCKET_NAME=<your_s3_bucket_name>
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0

# ── Firebase ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=<your_firebase_project_id>

# ── Gmail OAuth2 (Feature 1.1 – TNP Gmail Integration) ─────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Scopes needed: gmail.readonly
GOOGLE_CLIENT_ID=<your_google_oauth2_client_id>
GOOGLE_CLIENT_SECRET=<your_google_oauth2_client_secret>
GOOGLE_REDIRECT_URI=http://localhost:5001/api/gmail/callback

# 32-byte hex key for AES-256 encryption of Gmail refresh tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GMAIL_TOKEN_ENCRYPTION_KEY=<64_char_hex_string>

# ── App ────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
PORT=5000
FRONTEND_URL=http://localhost:5173
